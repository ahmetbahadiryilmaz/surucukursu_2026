{
  "name": "@surucukursu/database-service",
  "version": "1.0.0",
  "description": "Database migration and seeding service",
  "private": true,
  "scripts": {
    "migrate": "npx ts-node -r tsconfig-paths/register migrations/migrate.ts",
    "migrate:fresh": "npx ts-node -r tsconfig-paths/register migrations/migrate-fresh.ts",
    "seed": "npx ts-node -r tsconfig-paths/register seeder/run-seeder.ts",
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@surucukursu/shared": "workspace:*",
    "@jorgebodega/typeorm-seeding": "^7.1.0",
    "typeorm": "^0.3.27",
    "mysql2": "^3.15.2",
    "dotenv": "^16.0.0",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0"
  }
}
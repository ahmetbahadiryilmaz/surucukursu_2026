{
  "name": "@surucukursu/desktop",
  "version": "1.2.6",
  "description": "MTSK App Desktop Manager",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && concurrently -k --success first \"tsc -w\" \"wait-on dist/main/main.js && electron .\"",
    "dev:local": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && concurrently -k --success first \"tsc -w\" \"wait-on dist/main/main.js tcp:127.0.0.1:9501 && electron .\"",
    "watch": "tsc -w",
    "build:remote": "node scripts/build-remote.js",
    "bump:remote-version": "node scripts/bump-remote-version.js",
    "dist": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "esbuild": "^0.20.0",
    "wait-on": "^7.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.0.0",
    "@types/uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.mtsk.app",
    "productName": "MTSK_APP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://mtsk.app/desktop-updates"
    }
  }
}

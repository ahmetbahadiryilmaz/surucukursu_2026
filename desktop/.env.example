# Desktop app dev-mode backend overrides.
# Copy to `.env` (committed defaults) or `.env.local` (personal, gitignored).
# These are ONLY read in dev (app.isPackaged === false). Packaged builds
# always use the hardcoded production URLs.

# Backend API gateway base URL.
# Local:  http://127.0.0.1:9501
# Demo:   https://demo-api.mtsk.app
# Prod:   https://api.mtsk.app
DESKTOP_API_BASE_URL=http://127.0.0.1:9501

# Static updates host (latest.yml, minimum_version.json, installer exe).
# Defaults to DESKTOP_API_BASE_URL if unset.
# Prod equivalent: https://mtsk.app
# DESKTOP_UPDATES_BASE_URL=https://demo.mtsk.app
